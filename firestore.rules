rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// EDULLENT — Production Firestore Rules (SECURE baseline)
// ───────────────────────────────────────────────────────────────────────────
// Hardened 2026-04-18 — closes 12 critical tenant-isolation + IDOR bugs.
//
// Tenant model (unchanged):
//   • Owner's Firebase uid  ==  schoolId
//   • syncUserClaims Cloud Function writes { schoolId, role, branchId } onto
//     the ID token. Rules read those claims via request.auth.token.
//
// Public surfaces (intentional, tightened):
//   • access_requests  — public create (whitelisted fields + size caps)
//   • principals       — public get (lookup by id only, list denied)
//   • parent_tokens    — public get (token IS the auth), list denied
//
// Roles recognised in claims: 'owner' | 'principal' | 'teacher'
//                             'data_entry' | 'parent'
//
// ⚠ READ ENFORCEMENT NOTE:
//   Most collections now require list queries to filter by
//   schoolId == request.auth.token.schoolId. Client queries that used to run
//   bare (e.g. `collection('students').get()`) MUST be updated to include
//   `.where("schoolId", "==", schoolId)` before deploying these rules.
//   See docs/client-query-migration.md for the full checklist.
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // ── Helpers ───────────────────────────────────────────────────────────
    // ═══════════════════════════════════════════════════════════════════════

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function claimSchoolId() {
      return request.auth.token.schoolId;
    }

    function claimRole() {
      return request.auth.token.role;
    }

    function email() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    // Caller is owner of the given school (owner's uid == schoolId)
    function isOwnerOf(schoolId) {
      return signedIn() && uid() == schoolId;
    }

    // Caller's claims mark them as owner
    function hasOwnerRole() {
      return signedIn() && claimRole() == 'owner';
    }

    function hasStaffRole() {
      return signedIn() && claimRole() in ['owner', 'principal', 'teacher', 'data_entry'];
    }

    function hasAdminRole() {
      return signedIn() && claimRole() in ['owner', 'principal'];
    }

    // Same-tenant check — caller's claim schoolId matches existing doc's schoolId
    function inSameSchool() {
      return signedIn()
          && claimSchoolId() != null
          && 'schoolId' in resource.data
          && resource.data.schoolId == claimSchoolId();
    }

    // Write is addressed to caller's own school
    function writingToOwnSchool() {
      return signedIn()
          && claimSchoolId() != null
          && 'schoolId' in request.resource.data
          && request.resource.data.schoolId == claimSchoolId();
    }

    // New doc must carry a non-empty schoolId
    function hasSchoolId() {
      return 'schoolId' in request.resource.data
          && request.resource.data.schoolId is string
          && request.resource.data.schoolId.size() > 0
          && request.resource.data.schoolId.size() < 128;
    }

    // schoolId cannot change on update
    function schoolIdImmutable() {
      return request.resource.data.schoolId == resource.data.schoolId;
    }

    // Email match — for self-read/update patterns
    function ownsEmail() {
      return signedIn()
          && 'email' in resource.data
          && resource.data.email is string
          && resource.data.email.lower() == email();
    }

    // Parent-of-student check — used by leaderboard subcollections that key
    // on studentId in the path (e.g. /student_insights/{studentId}/...).
    //
    // The parent's login email may be stored EITHER in `students.email`
    // (this codebase's pattern — AuthContext.tsx queries by `email`) OR in
    // a separate `students.parentEmail` field (matches the alternative
    // pattern in /students/{id}'s existing rule). Both fields are valid;
    // we accept either match. Costs one document read per check (multiple
    // get() calls to the same path are deduplicated by the rules engine).
    function isParentOf(studentId) {
      return signedIn()
          && exists(/databases/$(database)/documents/students/$(studentId))
          && (
            ('email' in get(/databases/$(database)/documents/students/$(studentId)).data
             && get(/databases/$(database)/documents/students/$(studentId)).data.email is string
             && get(/databases/$(database)/documents/students/$(studentId)).data.email.lower() == email())
            ||
            ('parentEmail' in get(/databases/$(database)/documents/students/$(studentId)).data
             && get(/databases/$(database)/documents/students/$(studentId)).data.parentEmail is string
             && get(/databases/$(database)/documents/students/$(studentId)).data.parentEmail.lower() == email())
          );
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 1. OWNER SUBTREE — /schools/{ownerUid}/** ────────────────────────
    // ═══════════════════════════════════════════════════════════════════════
    match /schools/{schoolId} {
      allow read, write: if isOwnerOf(schoolId);

      match /{subPath=**} {
        // Owner reads everything under their tree.
        // Principals/teachers of same school can read (e.g. branches list)
        // but only owner can write.
        allow read: if isOwnerOf(schoolId)
                    || (signedIn() && claimSchoolId() == schoolId);
        allow write: if isOwnerOf(schoolId);
      }
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 2. PRINCIPALS ───────────────────────────────────────────────────
    //     Public GET only (RequestAccess page needs school name without
    //     login). LIST denied to prevent directory enumeration.
    // ═══════════════════════════════════════════════════════════════════════
    match /principals/{docId} {
      allow get:  if true;
      allow list: if signedIn() && (
                    hasOwnerRole()
                    || (claimSchoolId() != null
                        && resource.data.schoolId == claimSchoolId())
                  );

      allow create: if signedIn() && hasSchoolId() && isOwnerOf(request.resource.data.schoolId);
      allow delete: if isOwnerOf(resource.data.schoolId);

      // Update paths:
      //   1) Owner of the school
      //   2) Principal updating their OWN record
      //   schoolId immutable in both cases.
      allow update: if signedIn() && schoolIdImmutable() && (
        isOwnerOf(resource.data.schoolId)
        || ownsEmail()
      );
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 3. TEACHERS ─────────────────────────────────────────────────────
    // ═══════════════════════════════════════════════════════════════════════
    match /teachers/{docId} {
      allow get:  if signedIn() && (
                    hasOwnerRole()
                    || inSameSchool()
                    || ownsEmail()   // teacher can read own record pre-claims-sync
                  );
      allow list: if signedIn() && inSameSchool();

      // Create: only admins (owner/principal) of the target school.
      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && hasAdminRole();

      // Update:
      //   1) Owner of the school
      //   2) Principal of same school
      //   3) Teacher updating own record (status, lastLoginAt, isPrimarySchool)
      //   schoolId immutable in all cases.
      allow update: if signedIn() && schoolIdImmutable() && (
        isOwnerOf(resource.data.schoolId)
        || (claimRole() == 'principal' && resource.data.schoolId == claimSchoolId())
        || ownsEmail()
      );

      // Delete: only owner
      allow delete: if isOwnerOf(resource.data.schoolId);
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 4. STUDENTS ─────────────────────────────────────────────────────
    // ═══════════════════════════════════════════════════════════════════════
    match /students/{docId} {
      // Parent reads their own child's doc by email lookup; staff reads
      // any student in their school.
      allow get:  if signedIn() && (
                    hasOwnerRole()
                    || inSameSchool()
                    || ownsEmail()
                    || ('parentEmail' in resource.data
                        && resource.data.parentEmail is string
                        && resource.data.parentEmail.lower() == email())
                  );
      allow list: if signedIn() && inSameSchool();

      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();

      // Update: staff in same school, or the student themselves
      // (e.g. Invited → Active self-activation) with immutable schoolId.
      allow update: if signedIn() && schoolIdImmutable() && (
        (hasStaffRole() && resource.data.schoolId == claimSchoolId())
        || ownsEmail()
      );

      allow delete: if isOwnerOf(resource.data.schoolId)
                    || (claimRole() == 'principal' && resource.data.schoolId == claimSchoolId());
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 5. DATA ENTRY STAFF ─────────────────────────────────────────────
    // ═══════════════════════════════════════════════════════════════════════
    match /data_entry_staff/{docId} {
      allow get:  if signedIn() && (hasOwnerRole() || inSameSchool() || ownsEmail());
      allow list: if signedIn() && inSameSchool() && hasAdminRole();

      // Only admins can mint DEO accounts, and only for their own school.
      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && hasAdminRole();
      allow update: if signedIn() && schoolIdImmutable()
                    && resource.data.schoolId == claimSchoolId()
                    && (hasAdminRole() || ownsEmail());
      allow delete: if isOwnerOf(resource.data.schoolId)
                    || (claimRole() == 'principal' && resource.data.schoolId == claimSchoolId());
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 6. ACCESS REQUESTS — public intake, hardened ─────────────────────
    //     Anyone can submit, but field whitelist + size caps prevent DoS.
    // ═══════════════════════════════════════════════════════════════════════
    match /access_requests/{docId} {
      allow get:  if signedIn() && (hasOwnerRole() || (claimSchoolId() != null
                                  && resource.data.schoolId == claimSchoolId()));
      allow list: if signedIn() && hasAdminRole()
                  && (hasOwnerRole() || resource.data.schoolId == claimSchoolId());

      // Public create with strict schema validation.
      allow create: if request.resource.data.keys().hasOnly([
                        'schoolId','requestedBy','name','email','phone',
                        'note','role','status','createdAt'
                      ])
                    && request.resource.data.schoolId is string
                    && request.resource.data.schoolId.size() > 0
                    && request.resource.data.schoolId.size() < 128
                    && (!('email' in request.resource.data)
                        || (request.resource.data.email is string
                            && request.resource.data.email.size() < 200))
                    && (!('note' in request.resource.data)
                        || (request.resource.data.note is string
                            && request.resource.data.note.size() < 2000))
                    && (!('name' in request.resource.data)
                        || (request.resource.data.name is string
                            && request.resource.data.name.size() < 200));

      allow update: if signedIn() && hasAdminRole() && schoolIdImmutable()
                    && (hasOwnerRole() || resource.data.schoolId == claimSchoolId());
      allow delete: if isOwnerOf(resource.data.schoolId);
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 7. PARENT TOKENS — public-by-design share links ─────────────────
    //     GET is public (token == auth). LIST is DENIED — no enumeration.
    // ═══════════════════════════════════════════════════════════════════════
    match /parent_tokens/{token} {
      allow get:  if true;
      allow list: if false;

      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update: if false;   // tokens are write-once
      allow delete: if isOwnerOf(resource.data.schoolId)
                    || (hasAdminRole() && resource.data.schoolId == claimSchoolId());
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 8. AUDIT LOGS — append-only, owner-only read ────────────────────
    // ═══════════════════════════════════════════════════════════════════════
    match /audit_logs/{logId} {
      // Owner reads only their own school's audit trail.
      allow get, list: if signedIn() && hasOwnerRole()
                       && ('schoolId' in resource.data)
                       && resource.data.schoolId == claimSchoolId();

      // Only signed-in users can append. Cloud Functions use Admin SDK
      // which bypasses rules entirely — no unauthenticated clause needed.
      allow create: if signedIn();

      // NO updates, NO deletes — immutable audit trail.
      allow update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 9. GRADING JOBS — queue-based AI grading ────────────────────────
    // ═══════════════════════════════════════════════════════════════════════
    match /grading_jobs/{jobId} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if isOwnerOf(resource.data.schoolId);
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 10. OWNER STATS CACHE — written by Cloud Function ───────────────
    // ═══════════════════════════════════════════════════════════════════════
    match /owner_stats_cache/{ownerUid} {
      allow read:  if isOwnerOf(ownerUid);
      allow write: if isOwnerOf(ownerUid);
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 11. TENANT-SCOPED DATA COLLECTIONS ──────────────────────────────
    //     Single reusable pattern below via inline rules. Every collection
    //     enforces: read only in same school, writes only to own school,
    //     deletes only by admin role (owner or principal).
    // ═══════════════════════════════════════════════════════════════════════

    // ── Academic core ────────────────────────────────────────────────────
    match /attendance/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /results/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /test_scores/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /gradebook_scores/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /gradebook_columns/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasStaffRole();
    }
    match /assignments/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasStaffRole();
    }
    match /submissions/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /tests/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasStaffRole();
    }
    match /classes/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /enrollments/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /fees/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /fee_structure/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasAdminRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasAdminRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /exam_structure/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasAdminRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasAdminRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /incidents/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /discipline/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── Risk & intervention ─────────────────────────────────────────────
    match /risks/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /interventions/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /student_flags/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /student_smart_alerts/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /alert_resolutions/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /performance_feedback/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── Communications — principal ↔ teacher/parent ────────────────────
    match /principal_to_parent_notes/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      // Create: admin (principal/owner) can write any direction.
      // Parent/student replies are allowed only when from == "parent".
      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && (
                      hasAdminRole()
                      || (claimRole() in ['parent', 'student']
                          && request.resource.data.from == 'parent')
                    );
      // Update: admin can edit anything; parent/student may only flip the
      // `read` flag on incoming principal messages (no other field changes).
      allow update: if signedIn() && inSameSchool() && schoolIdImmutable() && (
                      hasAdminRole()
                      || (claimRole() in ['parent', 'student']
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']))
                    );
      allow delete: if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /principal_to_teacher_notes/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasAdminRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasAdminRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /parent_notes/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /communications/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /meetings/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /parent_meetings/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── Reports & analytics ─────────────────────────────────────────────
    match /reports/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /principal_reports/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasAdminRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasAdminRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /scheduled_reports/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── Teacher records ────────────────────────────────────────────────
    match /teaching_assignments/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasAdminRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasAdminRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /teacher_attendance/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasAdminRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasAdminRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }
    match /teacher_reviews/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasAdminRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasAdminRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── Timetable (class schedules) ────────────────────────────────────
    match /timetable/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── AI insight cache per student (24h TTL, refreshable) ─────────────
    match /student_ai_insights/{studentId} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── AI insight cache for branch + principal leaderboards (weekly TTL) ─
    //   Doc ID format: {schoolId}_{type}_{id}_W{weekNumber}
    //   Body stamps schoolId at top level so inSameSchool() can scope reads.
    //   Only principals/owners can write — these power the network leaderboard.
    match /leaderboard_ai_insights/{key} {
      allow get:    if signedIn() && inSameSchool();
      allow list:   if signedIn() && inSameSchool();
      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool()
                       && claimRole() in ['owner', 'principal'];
      allow update: if signedIn() && inSameSchool() && schoolIdImmutable()
                       && claimRole() in ['owner', 'principal'];
      allow delete: if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── Syllabus / class documents ─────────────────────────────────────
    match /syllabi/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole();
      allow delete:    if signedIn() && inSameSchool() && hasStaffRole();
    }

    // ── Owner → Principal notifications ────────────────────────────────
    match /owner_to_principal_notes/{id} {
      allow get:  if signedIn() && inSameSchool();
      allow list: if signedIn();  // TEMPORARY PHASE-1: relaxed while client queries migrate. Re-tighten to inSameSchool() once all pages filter by schoolId.
      allow create:    if signedIn() && hasSchoolId() && writingToOwnSchool() && hasOwnerRole();
      allow update:    if signedIn() && inSameSchool() && schoolIdImmutable() && hasAdminRole();
      allow delete:    if isOwnerOf(resource.data.schoolId);
    }

    // ── Public resources library (marketing content, videos) ───────────
    //   Collection used by populate_resources.js. Public read, writes only
    //   by authenticated staff (not open to clients).
    match /resources_library/{id} {
      allow get, list: if true;
      allow write:     if signedIn() && hasOwnerRole();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 11.5. EDULLENT LEADERBOARD — Cloud-Function-written collections ──
    // ═══════════════════════════════════════════════════════════════════════
    // All five collections below are written by the weekly leaderboard cron
    // (Phase 4) via the Admin SDK, which bypasses these rules entirely.
    // Rules here gate CLIENT reads + add defence-in-depth on the rare
    // staff-from-client write path (e.g. an admin tool deleting a stale doc).
    //
    // Path convention: every per-student weekly subcollection segment is
    // `weeks/{weekId}` — NOT a mix of `weekly/` and `weeks/`. A consistent
    // segment name prevents Phase 4 cron / Phase 5 hook fat-fingering.

    // ── Class leaderboard snapshots (one doc per class per week) ───────
    //   Doc path: /leaderboards/{schoolId}_{classId}/weeks/{weekId}
    //   Read gate: any signed-in user in the same school (matches the
    //   permissive precedent set by /student_ai_insights — class rankings
    //   are visible to every parent in the school).
    //   Write validator: doc body must reconstruct to the path classKey,
    //   so a buggy/malicious staff client cannot smuggle a doc into the
    //   wrong tenancy bucket (rules-only check; Admin SDK still bypasses).
    match /leaderboards/{classKey}/weeks/{weekId} {
      allow get:    if signedIn() && inSameSchool();
      allow list:   if signedIn() && inSameSchool();
      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole()
                       && (request.resource.data.schoolId + '_' + request.resource.data.classId == classKey)
                       && (request.resource.data.weekId == weekId);
      allow update: if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole()
                       && (request.resource.data.schoolId + '_' + request.resource.data.classId == classKey)
                       && (request.resource.data.weekId == weekId);
      allow delete: if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── Per-student composite weekly metrics ───────────────────────────
    //   Read gate is tighter than leaderboards: only the student's own
    //   parent (via parentEmail match) or same-school staff. List queries
    //   are staff-only because clients always read by full doc path.
    //   Write validator: data.studentId must match the path studentId, and
    //   data.weekId must match the path weekId.
    match /student_metrics/{studentId}/weeks/{weekId} {
      allow get:    if signedIn() && (
                      (hasStaffRole() && inSameSchool())
                      || isParentOf(studentId)
                    );
      allow list:   if signedIn() && hasStaffRole() && inSameSchool();
      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole()
                       && (request.resource.data.studentId == studentId)
                       && (request.resource.data.weekId == weekId);
      allow update: if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole()
                       && (request.resource.data.studentId == studentId)
                       && (request.resource.data.weekId == weekId);
      allow delete: if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── Per-student per-subject weekly metrics ─────────────────────────
    match /student_subject_metrics/{studentId}/weeks/{weekId} {
      allow get:    if signedIn() && (
                      (hasStaffRole() && inSameSchool())
                      || isParentOf(studentId)
                    );
      allow list:   if signedIn() && hasStaffRole() && inSameSchool();
      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole()
                       && (request.resource.data.studentId == studentId)
                       && (request.resource.data.weekId == weekId);
      allow update: if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole()
                       && (request.resource.data.studentId == studentId)
                       && (request.resource.data.weekId == weekId);
      allow delete: if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── AI-generated insights (diagnosis, action plan, forecast) ───────
    //   Doc path: /student_insights/{studentId}/weeks/{weekId}
    match /student_insights/{studentId}/weeks/{weekId} {
      allow get:    if signedIn() && (
                      (hasStaffRole() && inSameSchool())
                      || isParentOf(studentId)
                    );
      allow list:   if signedIn() && hasStaffRole() && inSameSchool();
      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole()
                       && (request.resource.data.studentId == studentId)
                       && (request.resource.data.weekId == weekId);
      allow update: if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole()
                       && (request.resource.data.studentId == studentId)
                       && (request.resource.data.weekId == weekId);
      allow delete: if signedIn() && inSameSchool() && hasAdminRole();
    }

    // ── Rolling rank history (single doc per student, last 12 weeks) ───
    match /student_rank_history/{studentId} {
      allow get:    if signedIn() && (
                      (hasStaffRole() && inSameSchool())
                      || isParentOf(studentId)
                    );
      allow list:   if signedIn() && hasStaffRole() && inSameSchool();
      allow create: if signedIn() && hasSchoolId() && writingToOwnSchool() && hasStaffRole()
                       && (request.resource.data.studentId == studentId);
      allow update: if signedIn() && inSameSchool() && schoolIdImmutable() && hasStaffRole()
                       && (request.resource.data.studentId == studentId);
      allow delete: if signedIn() && inSameSchool() && hasAdminRole();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ── 12. CATCH-ALL — deny unknown collections ────────────────────────
    // ═══════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}