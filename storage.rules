rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// EDULLENT — Production Firebase Storage Rules (SECURE baseline)
// ───────────────────────────────────────────────────────────────────────────
// Hardened 2026-04-18 — closes cross-tenant read/delete on syllabi,
// submissions, schools, profiles.
//
// Storage layout:
//   syllabi/{schoolId}/{branchId}/{classId}/{titleSlug}/{timestamp}_{fileName}
//   submissions/{schoolId}/{studentId}/{assignmentId}/{fileName}
//   schools/{schoolId}/** (logos, profile photos uploaded by owner)
//   profiles/{userId}/{fileName}
//
// Tenant check uses the schoolId segment from the path, compared against the
// caller's custom claim schoolId (set by syncUserClaims Cloud Function).
// ═══════════════════════════════════════════════════════════════════════════

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function claimSchoolId() {
      return request.auth.token.schoolId;
    }

    function claimRole() {
      return request.auth.token.role;
    }

    function hasOwnerRole() {
      return signedIn() && claimRole() == 'owner';
    }

    function hasStaffRole() {
      return signedIn() && claimRole() in ['owner', 'principal', 'teacher', 'data_entry'];
    }

    function hasAdminRole() {
      return signedIn() && claimRole() in ['owner', 'principal'];
    }

    // ── Platform-admin helpers (main-website /admin console) ─────────────
    // Mirror the Firestore-side platform-admin model. Storage rules can
    // call firestore.get / firestore.exists to read /admins/{uid}.
    function isPermanentPlatformSuper() {
      return signedIn()
          && request.auth.token.email_verified == true
          && request.auth.token.email != null
          && request.auth.token.email.lower() == 'edullentofficial@gmail.com';
    }

    function platformAdminData() {
      return firestore.get(/databases/(default)/documents/admins/$(uid())).data;
    }

    function hasPlatformAdminDoc() {
      return signedIn()
          && firestore.exists(/databases/(default)/documents/admins/$(uid()));
    }

    function isPlatformAdmin() {
      return isPermanentPlatformSuper()
          || (hasPlatformAdminDoc()
              && (platformAdminData().role == 'admin'
                  || platformAdminData().role == 'superadmin'));
    }

    function platformAdminHasSection(section) {
      return isPermanentPlatformSuper()
          || (hasPlatformAdminDoc()
              && (platformAdminData().role == 'superadmin'
                  || (platformAdminData().role == 'admin'
                      && 'sections' in platformAdminData()
                      && platformAdminData().sections is list
                      && section in platformAdminData().sections)));
    }

    // Caller's claimed school matches the {schoolId} segment of the path
    function sameSchool(schoolId) {
      return signedIn() && claimSchoolId() == schoolId;
    }

    function isOwnerOf(schoolId) {
      return signedIn() && uid() == schoolId;
    }

    // File type / size guards
    function isPdf() {
      return request.resource != null
          && request.resource.size < 50 * 1024 * 1024
          && request.resource.contentType == 'application/pdf';
    }

    function isAllowedSubmissionType() {
      return request.resource != null
          && request.resource.size < 50 * 1024 * 1024
          && request.resource.contentType in [
               'application/pdf',
               'image/jpeg', 'image/png', 'image/webp',
               'application/msword',
               'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
               'text/plain'
             ];
    }

    // Used by teacher assignment attachments + test blueprints.
    // 10 MB cap aligns with the client-side validator in CreateAssignment.tsx
    // and CreateTest.tsx (MAX_UPLOAD_BYTES = 10 MB).
    function isAllowedTeacherUploadType() {
      return request.resource != null
          && request.resource.size < 10 * 1024 * 1024
          && request.resource.contentType in [
               'application/pdf',
               'image/jpeg', 'image/png',
               'application/msword',
               'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
             ];
    }

    function isImage() {
      return request.resource != null
          && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    // Syllabus uploads: PDF + Office (Word/PowerPoint) + JPG/PNG, 50 MB cap.
    // Client-side validators enforce stricter limits (teacher PDF-only 50 MB,
    // principal 30 MB across all types) — this is the outer envelope.
    function isAllowedSyllabusType() {
      return request.resource != null
          && request.resource.size < 50 * 1024 * 1024
          && request.resource.contentType in [
               'application/pdf',
               'application/msword',
               'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
               'application/vnd.ms-powerpoint',
               'application/vnd.openxmlformats-officedocument.presentationml.presentation',
               'image/jpeg',
               'image/png'
             ];
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Syllabus / class documents ──────────────────────────────────────
    //   Authored by either teacher (their own classes) or principal (any
    //   class in their branch). Both write under the same 5-segment layout:
    //     syllabi/{schoolId}/{branchId}/{classId}/{authorBucket}/{fileName}
    //   where authorBucket is the teacher's titleSlug or the literal
    //   "principal".
    //   Read: signed-in same-school.
    //   Write: staff role in same school, allowed file type, 50 MB cap.
    //   Delete: staff role in same school (Firestore rule further restricts
    //           who can delete by author / admin).
    // ═════════════════════════════════════════════════════════════════════
    match /syllabi/{schoolId}/{branchId}/{classId}/{titleSlug}/{fileName} {
      allow read:   if sameSchool(schoolId);
      allow write:  if sameSchool(schoolId) && hasStaffRole() && isAllowedSyllabusType();
      allow delete: if sameSchool(schoolId) && hasStaffRole();
    }

    // ─── Important Questions (mirrors syllabi shape) ─────────────────────
    match /important_questions/{schoolId}/{branchId}/{classId}/{titleSlug}/{fileName} {
      allow read:   if sameSchool(schoolId);
      allow write:  if sameSchool(schoolId) && hasStaffRole() && isAllowedSyllabusType();
      allow delete: if sameSchool(schoolId) && hasStaffRole();
    }

    // ═════════════════════════════════════════════════════════════════════
    // ── Alumni PDFs ─────────────────────────────────────────────────────
    //   Path: alumni/{schoolId}/{branchId}/{fileName}
    //   Read: signed-in same-school (teachers + parents view).
    //   Write: principal/owner only — alumni docs are school-branding
    //          artefacts, not teacher-authored. Uses isPdf() helper which
    //          guards request.resource != null (resumable uploads have a
    //          session-init phase where request.resource is null; missing
    //          this guard caused 403 on every upload attempt).
    //   Delete: principal/owner only.
    // ═════════════════════════════════════════════════════════════════════
    match /alumni/{schoolId}/{branchId}/{fileName} {
      allow read:   if sameSchool(schoolId);
      allow write:  if sameSchool(schoolId) && hasAdminRole() && isPdf();
      allow delete: if sameSchool(schoolId) && hasAdminRole();
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Assignment submissions ──────────────────────────────────────────
    //   Read: signed-in same-school (students submit, teachers grade).
    //   Write: same-school + allowed mime types + 50 MB cap.
    //   Delete: staff role in same school, or the uploader themselves.
    // ═════════════════════════════════════════════════════════════════════
    match /submissions/{schoolId}/{allPaths=**} {
      allow read:   if sameSchool(schoolId);
      allow write:  if sameSchool(schoolId) && isAllowedSubmissionType();
      allow delete: if sameSchool(schoolId) && hasStaffRole();
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Owner / school assets (logos, branding) ─────────────────────────
    //   Read: any signed-in user in same school (logos shown in header).
    //   Write/Delete: owner of that school only, 10 MB cap, images only.
    // ═════════════════════════════════════════════════════════════════════
    match /schools/{schoolId}/{allPaths=**} {
      allow read:   if sameSchool(schoolId);
      allow write:  if isOwnerOf(schoolId)
                    && request.resource.size < 10 * 1024 * 1024
                    && isImage();
      allow delete: if isOwnerOf(schoolId);
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Assignment attachments (teacher creates) ────────────────────────
    //   Path: assignments/{teacherId}_{timestamp}_{fileName}
    //   Write: staff role only, and the filename MUST start with the
    //          uploader's UID — prevents one teacher from impersonating
    //          another teacher's file attribution.
    //   Read: any signed-in user (students/parents need to download) —
    //         actual file access goes through tokenized download URLs
    //         anyway, so this is defense in depth.
    //   Delete: staff role only.
    // ═════════════════════════════════════════════════════════════════════
    match /assignments/{fileName} {
      allow read:   if signedIn();
      allow write:  if hasStaffRole()
                    && fileName.matches(uid() + '_.*')
                    && isAllowedTeacherUploadType();
      allow delete: if hasStaffRole();
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Test blueprints (teacher creates) ───────────────────────────────
    //   Path: test_blueprints/{teacherId}_{timestamp}_{fileName}
    //   Same model as /assignments/ — uploader-scoped write, signed-in read.
    // ═════════════════════════════════════════════════════════════════════
    match /test_blueprints/{fileName} {
      allow read:   if signedIn();
      allow write:  if hasStaffRole()
                    && fileName.matches(uid() + '_.*')
                    && isAllowedTeacherUploadType();
      allow delete: if hasStaffRole();
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Profile photos ──────────────────────────────────────────────────
    //   Read: signed-in users (profile photos are displayed in directories,
    //         principals/teachers/parents need to see each other's avatars).
    //   Write/Delete: only the owner of that profile.
    // ═════════════════════════════════════════════════════════════════════
    match /profiles/{userId}/{fileName} {
      allow read:   if signedIn();
      allow write:  if signedIn() && uid() == userId
                    && request.resource.size < 5 * 1024 * 1024
                    && isImage();
      allow delete: if signedIn() && uid() == userId;
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Support ticket attachments (Help & Support page) ────────────────
    //   Path: support_uploads/{uploaderUid}/{batchId}/{fileName}
    //   Layout chosen so the uploader's UID is the FIRST segment after the
    //   collection — makes the write rule trivial (segment must match
    //   request.auth.uid). batchId is a client-generated uuid so multiple
    //   files in one ticket land under the same folder, enabling tidy
    //   delete-by-prefix.
    //
    //   Read: any signed-in user. Tokenised download URLs ARE the real
    //         access boundary here — the rule is defense in depth.
    //   Write: uploader = same UID, image-only, 10 MB cap per file.
    //   Delete: uploader OR support agent (mirrors Firestore ticket delete).
    // ═════════════════════════════════════════════════════════════════════
    match /support_uploads/{uploaderUid}/{batchId}/{fileName} {
      allow read:   if signedIn();
      allow write:  if signedIn()
                    && uid() == uploaderUid
                    && request.resource.size < 10 * 1024 * 1024
                    && isImage();
      allow delete: if signedIn() && uid() == uploaderUid;
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Principal Results PDFs (K-12 + Pre-Primary) ─────────────────────
    //   Paths:
    //     principal_results/{schoolId}/{resultId}/class.pdf
    //     principal_results/{schoolId}/{resultId}/{studentId}.pdf
    //     pp_principal_results/{schoolId}/{resultId}/class.pdf
    //     pp_principal_results/{schoolId}/{resultId}/{studentId}.pdf
    //
    //   Read: signed-in same-school. Per-student PDFs live at random
    //   resultId+studentId paths that aren't enumerable without Firestore
    //   access; the Firestore rule only returns the row to in-scope callers.
    //
    //   Write/Delete: principal or owner only (teachers cannot publish).
    //   PDF only, 10 MB cap (matches client validator).
    // ═════════════════════════════════════════════════════════════════════
    match /principal_results/{schoolId}/{resultId}/{fileName} {
      allow read:   if sameSchool(schoolId);
      allow write:  if sameSchool(schoolId) && hasAdminRole() && isPdf();
      allow delete: if sameSchool(schoolId) && hasAdminRole();
    }

    match /pp_principal_results/{schoolId}/{resultId}/{fileName} {
      allow read:   if sameSchool(schoolId);
      allow write:  if sameSchool(schoolId) && hasAdminRole() && isPdf();
      allow delete: if sameSchool(schoolId) && hasAdminRole();
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Main-website article images ─────────────────────────────────────
    //   Path: articles/{articleId}/{fileName}
    //   Read: public — articles are visitor-facing on the marketing site.
    //   Write: platform admins with the 'articles' section grant (or
    //          permanent superadmin / superadmin). Image MIME only, 10 MB cap.
    //   Delete: same gate as write.
    // ═════════════════════════════════════════════════════════════════════
    match /articles/{articleId}/{fileName} {
      allow read:   if true;
      allow write:  if platformAdminHasSection('articles')
                    && request.resource.size < 10 * 1024 * 1024
                    && isImage();
      allow delete: if platformAdminHasSection('articles');
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── CATCH-ALL — deny unknown paths ──────────────────────────────────
    // ═════════════════════════════════════════════════════════════════════
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}