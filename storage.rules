rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// EDULLENT — Production Firebase Storage Rules
// ───────────────────────────────────────────────────────────────────────────
// Storage layout:
//   syllabi/{schoolId}/{branchId}/{classId}/{titleSlug}/{timestamp}_{fileName}
//     — Teacher uploads class documents (syllabus, notes, resources)
//     — Read: any signed-in user in same school
//     — Write: any signed-in user writing into their own schoolId
//
// Deploy:
//   firebase deploy --only storage
// ═══════════════════════════════════════════════════════════════════════════

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isOwnerOf(schoolId) {
      return signedIn() && uid() == schoolId;
    }

    // PDF-only + 50 MB cap
    function isValidPdf() {
      return request.resource != null
          && request.resource.size < 50 * 1024 * 1024
          && request.resource.contentType == 'application/pdf';
    }

    // ═════════════════════════════════════════════════════════════════════
    // ── Syllabus / class documents ──────────────────────────────────────
    //   Path: syllabi/{schoolId}/{branchId}/{classId}/{title}/{filename}
    //   Read: any signed-in user (client-side Firestore rules enforce
    //         cross-tenant isolation — only docs for your class are listed)
    //   Write: signed-in + schoolId path segment must match a valid user
    //   Delete: signed-in (creator or principal)
    // ═════════════════════════════════════════════════════════════════════
    match /syllabi/{schoolId}/{branchId}/{classId}/{titleSlug}/{fileName} {
      allow read: if signedIn();

      // Write: PDF only + 50 MB cap + must be signed in
      // (Firestore doc write is what enforces tenant isolation; storage
      //  rules just validate file type + size at upload time)
      allow write: if signedIn() && isValidPdf();

      // Delete: signed-in user (creator or principal cleanup)
      allow delete: if signedIn();
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Assignment submissions (if used elsewhere) ──────────────────────
    //   Keep existing permissive pattern if you already use /submissions/
    // ═════════════════════════════════════════════════════════════════════
    match /submissions/{schoolId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.resource.size < 50 * 1024 * 1024;
      allow delete: if signedIn();
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Owner / school assets (logos, profile photos) ───────────────────
    // ═════════════════════════════════════════════════════════════════════
    match /schools/{schoolId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isOwnerOf(schoolId)
                   && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isOwnerOf(schoolId);
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── Student / teacher / principal profile photos ────────────────────
    // ═════════════════════════════════════════════════════════════════════
    match /profiles/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && uid() == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if signedIn() && uid() == userId;
    }


    // ═════════════════════════════════════════════════════════════════════
    // ── CATCH-ALL — deny unknown paths ──────────────────────────────────
    //   Any storage path NOT matching above is BLOCKED.
    // ═════════════════════════════════════════════════════════════════════
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}